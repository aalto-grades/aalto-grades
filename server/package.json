{
  "name": "aalto-grades-server",
  "license": "Expat (MIT)",
  "author": "The Ossi Developers",
  "scripts": {
    "build": "pnpm run clean && tsc && tsc-alias",
    "citest": "GITHUB_ACTIONS=1 jest --detectOpenHandles",
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/server.ts",
    "dev:otel": "export OTEL_LOG_LEVEL='info'; export OTEL_SERVICE_NAME='ossi-dev-node'; NODE_OPTIONS='--require @opentelemetry/auto-instrumentations-node/register' ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/server.ts",
    "dev:winston": "export OTEL_LOG_LEVEL='all'; export OTEL_NODE_ENABLED_INSTRUMENTATIONS='winston'; export OTEL_SERVICE_NAME='ossi-dev-node'; NODE_OPTIONS='--require @opentelemetry/auto-instrumentations-node/register' ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/server.ts",
    "lint": "eslint . --report-unused-disable-directives",
    "lint:fix": "eslint . --report-unused-disable-directives --fix",
    "migration:down": "pnpm exec sequelize-cli db:migrate:undo",
    "migration:down:all": "pnpm exec sequelize-cli db:migrate:undo:all",
    "migration:up": "pnpm exec sequelize-cli db:migrate",
    "seed:down": "pnpm exec sequelize-cli db:seed:undo:all",
    "seed:up": "pnpm exec sequelize-cli db:seed:all",
    "start": "node build/server/src/server.js",
    "test": "jest --verbose --detectOpenHandles --coverage",
    "clean": "rimraf build"
  },
  "dependencies": {
    "@node-saml/passport-saml": "^5.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/winston-transport": "^0.28.0",
    "@simplewebauthn/server": "^13.3.1",
    "@xmldom/xmldom": "^0.9.10",
    "argon2": "^0.44.0",
    "axios": "^1.17.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-stringify": "^6.7.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "generate-password": "^1.7.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "otplib": "^13.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.21.0",
    "rate-limiter-flexible": "^11.1.1",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "xpath": "^0.0.34",
    "zod": "^4.4.3",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.2",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "cookiejar": "^2.1.4",
    "jest": "^30.4.2",
    "mockdate": "^3.0.5",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=26"
  },
  "overrides": {
    "This does not work, because npm is f*** bugged": "maybe one day...",
    "@types/express": "^5.0.0",
    "@node-saml/passport-saml": {
      "@types/express": "^5.0.0"
    }
  }
}