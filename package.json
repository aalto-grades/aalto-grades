{
  "name": "ossi",
  "version": "1.0.11",
  "license": "MIT",
  "author": "The Ossi Developers",
  "type": "module",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^26.3.1",
      "onFail": "download"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.2.0",
      "onFail": "download"
    }
  },
  "workspaces": [
    "client",
    "server",
    "e2e-tests",
    "common"
  ],
  "scripts": {
    "lint": "eslint . --report-unused-disable-directives --concurrency=auto",
    "lint-common": "eslint common --report-unused-disable-directives",
    "lint-common:fix": "eslint common --report-unused-disable-directives --fix",
    "lint:fix": "eslint . --report-unused-disable-directives --fix"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-yml": "^3.4.0",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}