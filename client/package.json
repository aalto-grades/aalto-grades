{
  "name": "ossi-client",
  "type": "module",
  "license": "MIT",
  "author": "The Ossi Developers",
  "scripts": {
    "build": "tsc -b && vite build",
    "lint": "eslint . --report-unused-disable-directives",
    "lint:fix": "eslint . --report-unused-disable-directives --fix",
    "preview": "vite preview --port 3005",
    "prod-licenses": "npx license-checker-rseidelsohn --excludePrivatePackages --production --summary",
    "start": "vite",
    "trans-copy": "cp public/locales/en/translation.json ./",
    "trans-merge": "npx tsx translation-utils.ts merge",
    "trans-parse": "npx i18next 'src/**/*.{ts,tsx}' -c i18next-parser.config.js -o 'public/locales/$LOCALE/$NAMESPACE.json'",
    "trans-rename": "npx tsx translation-utils.ts rename"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/types": "^9.0.0",
    "@mui/x-data-grid": "^9.0.4",
    "@mui/x-date-pickers": "^9.0.4",
    "@simplewebauthn/browser": "^13.3.0",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-devtools": "^5.100.9",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/spdx-expression-parse": "^4.0.0",
    "@xyflow/react": "^12.10.2",
    "axios": "^1.16.0",
    "cheerio": "^1.2.0",
    "dayjs": "^1.11.20",
    "dompurify": "^3.4.2",
    "elkjs": "^0.11.1",
    "formik": "^2.4.9",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-cli": "^1.56.9",
    "i18next-http-backend": "^4.0.0",
    "mui-one-time-password-input": "^7.0.0",
    "notistack": "^3.0.2",
    "papaparse": "^5.5.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-global-modal": "github:gubo97000/react-global-modal",
    "react-i18next": "^17.0.6",
    "react-qr-code": "^2.0.21",
    "react-router-dom": "^7.15.0",
    "styled-components": "^6.4.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/readline-sync": "^1.4.8",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "license-checker-rseidelsohn": "^4.4.2",
    "readline-sync": "^1.4.10",
    "rollup-plugin-license": "^3.7.1",
    "sass": "^1.99.0",
    "spdx-expression-parse": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}